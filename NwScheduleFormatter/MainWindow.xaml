<Window x:Class="NwScheduleFormatter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NwScheduleFormatter"
        mc:Ignorable="d"
        Title="MainWindow" Height="400" Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Month selection label and combobox -->
        <TextBlock Grid.Row="0" Text="Year:" Margin="0,0,0,2" />
        <ComboBox x:Name="YearComboBox" Grid.Row="1" Height="30" VerticalAlignment="Top" Margin="0,0,0,8" />

        <!-- Month selection label and combobox -->
        <TextBlock Grid.Row="2" Text="Month:" Margin="0,0,0,2" />
        <ComboBox x:Name="MonthComboBox" Grid.Row="3" Height="30" VerticalAlignment="Top" Margin="0,0,0,8" />

        <!-- Input file label and chooser -->
        <TextBlock Grid.Row="4" Text="Input file:" Margin="0,0,0,2" />
        <StackPanel Grid.Row="5" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
            <TextBox x:Name="InputFileTextBox" Width="520" VerticalAlignment="Center" />
            <Button x:Name="BrowseInputButton" Content="Browse..." Width="80" Margin="8,0,0,0" />
        </StackPanel>

        <!-- Output directory label and chooser -->
        <TextBlock Grid.Row="6" Text="Output directory:" Margin="0,0,0,2" />
        <StackPanel Grid.Row="7" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
            <TextBox x:Name="DirectoryTextBox" Width="520" VerticalAlignment="Center" />
            <Button x:Name="BrowseButton" Content="Browse..." Width="80" Margin="8,0,0,0" />
        </StackPanel>

        <!-- File name label and input -->
        <TextBlock Grid.Row="8" Text="File name:" Margin="0,0,0,2" />
        <TextBox x:Name="FileNameTextBox" Grid.Row="9" Height="30" VerticalAlignment="Top" />

        <!-- Generate button -->
        <Button x:Name="GenerateButton" Grid.Row="10" Content="Generate" Width="100" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Click="GenerateButton_Click" />
    </Grid>
</Window>
